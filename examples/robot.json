{
  "platform": "esp32",
  "i2c": {
    "i2c0": { "sda": 21, "scl": 22, "freq": 400000 }
  },
  "uart": {
    "uart1": { "tx": 17, "rx": 16, "baud": 1000000 }
  },
  "motors": {
    "left": {
      "driver": "jgb37_520",
      "in1": 25, "in2": 26, "pwm": 27,
      "encoder_a": 32, "encoder_b": 33,
      "counts_per_output_rev": 1320
    },
    "right": {
      "driver": "jgb37_520",
      "in1": 14, "in2": 12, "pwm": 13,
      "encoder_a": 34, "encoder_b": 35,
      "counts_per_output_rev": 1320,
      "invert": true
    }
  },
  "servos": {
    "arm": {
      "driver": "st3215",
      "servo_id": 1,
      "uart_id": 1,
      "tx": 17, "rx": 16,
      "baud": 1000000
    }
  },
  "sensors": {
    "imu":   { "driver": "bno055",   "bus": "i2c0" },
    "color": { "driver": "tcs34725", "bus": "i2c0", "integration_ms": 50, "gain": 4 }
  },
  "drivebase": {
    "left": "left",
    "right": "right",
    "wheel_diameter_mm": 65,
    "axle_track_mm": 120
  }
}
