<!--
  WRO 2026 RoboMission Elementary — "Robot Rockstars"
  =====================================================

  Theme: the robot sets up a music festival. Missions (from the
  official Game Rules PDF, 2026-01-15):

    3.1  Connect the amplifier with the speakers
           2 cables → grey target areas, upright.
           15 pts each (30 max), 5 partial. +30 bonus both completed.
    3.2  Prepare the show
           3 instruments (guitar, keyboard, congas) → backstage
             (pink) area. 15 pts each, 45 max.
           1 microphone → mic target area (light green), upright.
             20 pts full, 10 partial.
    3.3  Play the song
           6 notes (red/blue/green/yellow/white/black) → matching
             colour note target areas (grey border).
             20 pts each upright-in-correct-colour, 10 partial, 120 max.
    3.4  Bonus — don't damage/move:
           Clef ............. 10
           Speakers (×2) .... 20
           Amplifier ........ 10

  Max round score: 255.

  Mat: 2362 × 1143 mm — the printed artwork is used directly as a
  MuJoCo texture on a plane geom (``mat.png`` in this
  directory). Every zone visible in the artwork is therefore pixel-
  accurate without any zone geoms of our own; only the physical
  props + walls sit as 3-D objects on top.

  Prop dimensions use the LEGO reality: stud pitch 8 mm, brick
  height 9.6 mm, plate height 3.2 mm. Counts are read from the
  official Building Instructions PDF; fine geometry (angled
  handles, knob arrays) collapses to axis-aligned boxes for the
  physics. Good enough for pushing/catching behaviour; swap to
  STL/mesh once someone hand-models the LEGO shapes in Blender.

  Origin at mat centre. +X = long axis (towards start area on the
  right). +Y = short axis (towards stage on top). +Z = up. All
  dimensions in metres.
-->

<mujoco model="wro_2026_elementary_robot_rockstars">
  <compiler angle="degree" coordinate="local"/>

  <!-- 1 kHz physics to match the firmware control loop. -->
  <option timestep="0.001" iterations="20" solver="Newton"/>

  <asset>
    <!-- The actual printed mat as a texture. ``texrepeat="1 1"``
         stretches it exactly once over the 2.362 × 1.143 m plane. -->
    <texture name="mat_tex" type="2d" file="mat.png"/>
    <material name="mat" texture="mat_tex" texrepeat="1 1"
              specular="0" shininess="0" reflectance="0"/>

    <!-- Border walls. -->
    <material name="wall" rgba="0.90 0.90 0.90 1"/>

    <!-- LEGO prop colours. Brick shades picked to match the build
         instructions' standard parts palette. -->
    <material name="lego_blue"    rgba="0.10 0.30 0.80 1"/>
    <material name="lego_red"     rgba="0.85 0.10 0.10 1"/>
    <material name="lego_yellow"  rgba="0.95 0.80 0.10 1"/>
    <material name="lego_green"   rgba="0.15 0.70 0.25 1"/>
    <material name="lego_white"   rgba="0.95 0.95 0.95 1"/>
    <material name="lego_black"   rgba="0.08 0.08 0.08 1"/>
    <material name="lego_gray"    rgba="0.55 0.55 0.58 1"/>
  </asset>

  <worldbody>
    <!-- Overhead lighting (two sources for even colour on the camera
         sensor reading the mat). -->
    <light pos=" 0.6 0 1.6" dir="0 0 -1" diffuse="0.95 0.95 0.95"/>
    <light pos="-0.6 0 1.6" dir="0 0 -1" diffuse="0.65 0.65 0.65"/>

    <!-- ===== MAT (2.362 × 1.143 m, printed texture) ===== -->
    <geom name="mat" type="plane" size="1.181 0.5715 0.01"
          material="mat" friction="0.8 0.02 0.0001"/>

    <!-- Border walls — 40 mm tall, 15 mm thick. Keep props on-mat. -->
    <geom name="wall_n" type="box" pos=" 0     0.579  0.02"
          size="1.181 0.0075 0.02" material="wall"/>
    <geom name="wall_s" type="box" pos=" 0    -0.579  0.02"
          size="1.181 0.0075 0.02" material="wall"/>
    <geom name="wall_e" type="box" pos=" 1.188 0      0.02"
          size="0.0075 0.5715 0.02" material="wall"/>
    <geom name="wall_w" type="box" pos="-1.188 0      0.02"
          size="0.0075 0.5715 0.02" material="wall"/>

    <!-- =========================================================
         STATIC SCENERY / BONUS-PROTECTED OBJECTS (mission 3.4 —
         10/20/10 pts if left where they started, upright).

         These are static in the physics sense but have ``<body>``
         wrappers with a ``<freejoint/>`` so the sim can detect
         "moved or damaged". Mass is high enough (~200 g) that a
         well-driven openbricks robot won't nudge them; a bad line
         will. Swap to ``geom`` (no joint) if you want them bolted
         to the mat for the demo.
         ========================================================= -->

    <!-- Clef: F2.1 LDraw-built blue brick tower on a 4x6 white plate
         base. The ``<lego_prop>`` placeholder is expanded by
         ``world.py`` at load time using ``props/clef.ldr`` (BI steps
         1-14, 30 blue bricks + 1 plate, ≈48 g). -->
    <lego_prop name="clef" ldr="props/clef.ldr" pos="-0.08 0.12 0.0" mass="0.048"/>

    <!-- Amplifier: tall black/blue stack, ~4×5 stud footprint,
         ~10 bricks tall. Upper-left of stage. -->
    <body name="amplifier" pos="-1.02  0.30  0.050">
      <freejoint/>
      <geom type="box" size="0.020 0.024 0.050" mass="0.15" material="lego_blue"/>
    </body>

    <!-- Speakers (×2): smaller black stacks with cones (cylinders
         simplified). ~3×3 footprint, ~7 bricks tall. On stage near
         the cable target zones. -->
    <body name="speaker_upper" pos="-0.62  0.32  0.035">
      <freejoint/>
      <geom type="box" size="0.016 0.016 0.035" mass="0.08" material="lego_black"/>
    </body>
    <body name="speaker_lower" pos="-0.62 -0.32  0.035">
      <freejoint/>
      <geom type="box" size="0.016 0.016 0.035" mass="0.08" material="lego_black"/>
    </body>

    <!-- =========================================================
         MISSION 3.1 — cables (movable, score when upright in the
         grey target areas printed on the mat between the amplifier
         and each speaker).
         ========================================================= -->
    <!-- F2.2: each cable is ~22 LEGO bricks (yellow plate base + white
         body + 1x6 black technic-brick "cable wire" running through the
         middle + yellow caps), generated from props/cable.ldr at load
         time. Two instances at the upper / lower target zones. -->
    <lego_prop name="cable_upper" ldr="props/cable.ldr" pos="-0.82 0.30 0.0" mass="0.040"/>
    <lego_prop name="cable_lower" ldr="props/cable.ldr" pos="-0.82 -0.30 0.0" mass="0.040"/>

    <!-- =========================================================
         MISSION 3.2 — instruments start in the backstage-start
         area (truck at the bottom-middle). Microphone starts there
         too per the PDF. The robot delivers the 3 instruments to
         the pink backstage-target area (bottom-left) and the
         microphone to the light-green mic-target zone on the
         stage.
         ========================================================= -->

    <!-- F2.3: instruments + microphone as LDraw assemblies. Each
         prop's brick layout lives in props/<name>.ldr; the
         <lego_prop> placeholder gets expanded by world.py at load
         time. -->
    <lego_prop name="guitar"     ldr="props/guitar.ldr"     pos="0.85 -0.40 0.0" mass="0.100"/>
    <lego_prop name="keyboard"   ldr="props/keyboard.ldr"   pos="0.62 -0.42 0.0" mass="0.130"/>
    <lego_prop name="congas"     ldr="props/congas.ldr"     pos="0.40 -0.42 0.0" mass="0.120"/>
    <lego_prop name="microphone" ldr="props/microphone.ldr" pos="-0.15 -0.42 0.0" mass="0.030"/>

    <!-- =========================================================
         MISSION 3.3 — 6 notes. Each is a coloured piece with a
         distinct silhouette (different shapes ease both sensor
         disambiguation and the rule's "different shapes"
         requirement). Starting positions are on 4 light-green
         squares at the upper-right of the mat; actual placement
         is randomized each round — these six are a nominal seed.

         Exact shapes per the rules: one per colour. We approximate
         with pillar/sphere/flat-brick/tall-brick/half-cyl/rod so a
         downward camera sensor can tell them apart.
         ========================================================= -->
    <!-- F2.4: 6 notes as LDraw assemblies. Each note has a 2x2
         plate base (common across all 6 — required by the rules)
         and a distinct upper silhouette so the chassis colour
         sensor + the per-note shape can disambiguate. Same
         positions as the 0.10.x placeholders; the F3 randomization
         in randomization.py permutes the 4 random notes (black /
         white / yellow / blue) across slot_1..slot_4 each round. -->
    <lego_prop name="note_red"    ldr="props/note_red.ldr"    pos="0.50 0.40 0.0" mass="0.020"/>
    <lego_prop name="note_blue"   ldr="props/note_blue.ldr"   pos="0.65 0.40 0.0" mass="0.020"/>
    <lego_prop name="note_green"  ldr="props/note_green.ldr"  pos="0.80 0.40 0.0" mass="0.020"/>
    <lego_prop name="note_yellow" ldr="props/note_yellow.ldr" pos="0.95 0.40 0.0" mass="0.020"/>
    <lego_prop name="note_white"  ldr="props/note_white.ldr"  pos="0.50 0.25 0.0" mass="0.020"/>
    <lego_prop name="note_black"  ldr="props/note_black.ldr"  pos="0.80 0.25 0.0" mass="0.020"/>

    <!-- =========================================================
         OVERHEAD CAMERA for previewing the whole scene in MuJoCo's
         viewer. openbricks-sim will attach its own chassis-mounted
         downward camera for the TCS34725 colour sensor shim.
         ========================================================= -->
    <camera name="overhead" pos="0 0 2.6" xyaxes="1 0 0 0 1 0"/>
  </worldbody>
</mujoco>
