<!--
  WRO 2026 RoboMission Senior — "Mosaic Masters"
  ================================================

  Theme: a mosaic-tile-pattern construction site. The robot acts as
  an apprentice mason — provides tools to colleagues, lays mosaic
  tiles in a frame, delivers cement to colour-coded targets, and
  protects the barriers around the work site.

  Missions (from the official Game Rules PDF, 2026-01-15):

    3.1  Provide the tools
           Rectangular trowel → sponsor area. 15 full / 5 partial.
           Cement bowl       → parking space. 15 full / 5 partial.
           Masonry trowel    → start area.    15 full / 5 partial.
    3.2  Put the mosaic in place
           Up to 12 mosaic tiles in the mosaic frame, correctly
             oriented + colour-matched + on-the-ground.
             10 each correct (max 120). 5 each incorrect.
    3.3  Deliver the cement
           Up to 40 cement elements (10×each colour: yellow, blue,
             green, white) placed in matching-colour cement target
             areas. 1 each (max 40).
    3.4  Bonus for barriers
           4 barriers (2 red w/ blue balls, 2 black w/ red balls)
             not damaged or moved. 7 each (max 28).

  Max round score: 233.

  Mat: 2362 × 1143 mm — official printed artwork as MuJoCo texture
  (mat.png in this directory). Origin at mat centre. +X = long
  axis, +Y = short, +Z = up. Metres.
-->

<mujoco model="wro_2026_senior_mosaic_masters">
  <compiler angle="degree" coordinate="local"/>

  <option timestep="0.001" iterations="20" solver="Newton"/>

  <asset>
    <texture name="mat_tex" type="2d" file="mat.png"/>
    <material name="mat" texture="mat_tex" texrepeat="1 1"
              specular="0" shininess="0" reflectance="0"/>
    <material name="wall" rgba="0.90 0.90 0.90 1"/>

    <material name="lego_red"     rgba="0.85 0.10 0.10 1"/>
    <material name="lego_yellow"  rgba="0.95 0.80 0.10 1"/>
    <material name="lego_green"   rgba="0.15 0.70 0.25 1"/>
    <material name="lego_blue"    rgba="0.10 0.30 0.80 1"/>
    <material name="lego_white"   rgba="0.95 0.95 0.95 1"/>
    <material name="lego_black"   rgba="0.08 0.08 0.08 1"/>
    <material name="lego_gray"    rgba="0.55 0.55 0.58 1"/>
  </asset>

  <worldbody>
    <light pos=" 0.6 0 1.6" dir="0 0 -1" diffuse="0.95 0.95 0.95"/>
    <light pos="-0.6 0 1.6" dir="0 0 -1" diffuse="0.65 0.65 0.65"/>

    <!-- ===== MAT (2.362 × 1.143 m, printed texture) ===== -->
