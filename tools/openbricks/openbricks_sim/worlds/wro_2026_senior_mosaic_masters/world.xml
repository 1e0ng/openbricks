    <lego_prop name="barrier_red_b"   ldr="props/senior_barrier.ldr" pos="0.20 0.18 0.0"   mass="0.070" color="red"/>
    <lego_prop name="barrier_black_a" ldr="props/senior_barrier.ldr" pos="-0.20 -0.18 0.0" mass="0.070" color="black"/>
    <lego_prop name="barrier_black_b" ldr="props/senior_barrier.ldr" pos="0.20 -0.18 0.0"  mass="0.070" color="black"/>

