          material="mat" friction="0.8 0.02 0.0001"/>

    <geom name="wall_n" type="box" pos=" 0     0.579  0.02"
          size="1.181 0.0075 0.02" material="wall"/>
    <geom name="wall_s" type="box" pos=" 0    -0.579  0.02"
          size="1.181 0.0075 0.02" material="wall"/>
    <geom name="wall_e" type="box" pos=" 1.188 0      0.02"
          size="0.0075 0.5715 0.02" material="wall"/>
    <geom name="wall_w" type="box" pos="-1.188 0      0.02"
          size="0.0075 0.5715 0.02" material="wall"/>

    <!-- =========================================================
         F2.7: All Senior props as LDraw assemblies. Shared geometry
         .ldr files (senior_barrier, mosaic_tile, cement_element)
         use the lego_prop ``color`` attribute to drive colour at
         load time, so a single file does duty for all instances
         differing only in colour. The F3.S randomization spec
         (separate PR) randomises cement-element positions within
         their matching-colour cement target areas, and the mosaic
         pattern via paper-under-frame.
         ========================================================= -->

    <!-- Mission 3.4: 4 barriers (bonus, don't damage). -->
