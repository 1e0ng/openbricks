# SPDX-License-Identifier: MIT
# openbricks-specific ESP-IDF sdkconfig overrides for ESP32-S3.
#
# v1.0.4: minimum-divergence config. Stock MicroPython
# ``ESP32_GENERIC_S3-SPIRAM_OCT`` boots fine on the AP_3v3 chip we
# tested with; everything we'd previously layered on (WiFi disable,
# USB-Serial-JTAG console override, INFO log levels) was a
# bring-up hypothesis that turned out not to fix the silent-boot
# issue and may have been the cause. Strip back to just the
# flash-mode pin (QIO/80 MHz) — match upstream — and let IDF
# pick its defaults for everything else.
#
# The frozen ``main.py`` (loads BLE on every boot) is the next
# suspect; that's a Python-side change covered in the same PR.
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
