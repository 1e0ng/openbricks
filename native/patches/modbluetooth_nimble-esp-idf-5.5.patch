diff --git a/extmod/nimble/modbluetooth_nimble.c b/extmod/nimble/modbluetooth_nimble.c
index 6b000f77f..642d4fb68 100644
--- a/extmod/nimble/modbluetooth_nimble.c
+++ b/extmod/nimble/modbluetooth_nimble.c
@@ -584,12 +584,38 @@ void nimble_reset_gatts_bss(void) {
     // These variables are defined in ble_hs.c and are only ever incremented
     // (during service registration) and never reset.
     // See https://github.com/apache/mynewt-nimble/issues/896
+    //
+    // ESP-IDF 5.5+ redefines these three as preprocessor macros in
+    // ble_hs_priv.h (expanded to fields of ``ble_hs_state_ctx`` — a
+    // POINTER that's NULL until NimBLE allocates the host-state
+    // struct during its own init). Two implications:
+    //
+    //   1. ``extern uint16_t name;`` fails to compile because the
+    //      macro substitutes inside the declaration. Use ``#ifndef``
+    //      to skip the extern-form on newer ESP-IDF.
+    //   2. The assignments ``name = 0`` expand to
+    //      ``ble_hs_state_ctx->max_attrs = 0``. On the FIRST
+    //      ``ble.active(True)`` call, ``ble_hs_state_ctx`` is NULL
+    //      — assigning crashes with a NULL+offset store
+    //      (``EXCVADDR=0x00000002`` for the uint16_t at struct
+    //      offset 2). Guard with a NULL check on newer IDF; the
+    //      reset only matters for re-init scenarios anyway, so
+    //      skipping on first init is safe.
+#ifndef ble_hs_max_attrs
     extern uint16_t ble_hs_max_attrs;
     extern uint16_t ble_hs_max_services;
     extern uint16_t ble_hs_max_client_configs;
     ble_hs_max_attrs = 0;
     ble_hs_max_services = 0;
     ble_hs_max_client_configs = 0;
+#else
+    extern ble_hs_state_ctx_t *ble_hs_state_ctx;
+    if (ble_hs_state_ctx != NULL) {
+        ble_hs_max_attrs = 0;
+        ble_hs_max_services = 0;
+        ble_hs_max_client_configs = 0;
+    }
+#endif
 }
 
